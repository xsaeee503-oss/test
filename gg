<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>@ecgl Test</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,Helvetica,sans-serif;
}

body{
    background:#0d0d12;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
}

.window{
    width:500px;
    background:#181820;
    border:2px solid #8b5cf6;
    border-radius:12px;
    overflow:hidden;
    box-shadow:0 0 40px rgba(139,92,246,.4);
}

.titlebar{
    background:#8b5cf6;
    color:white;
    padding:12px;
    font-size:18px;
    font-weight:bold;
}

.content{
    padding:25px;
    color:white;
}

input{
    width:100%;
    margin-top:10px;
    padding:12px;
    border:none;
    border-radius:8px;
    background:#262633;
    color:white;
}

button{
    margin-top:20px;
    width:100%;
    padding:12px;
    border:none;
    border-radius:8px;
    background:#8b5cf6;
    color:white;
    font-size:16px;
    cursor:pointer;
    transition:.2s;
}

button:hover{
    background:#9d70ff;
}

#status{
    margin-top:20px;
    color:#7cff9b;
    font-weight:bold;
}
</style>

</head>
<body>

<div class="window">

    <div class="titlebar">
        @ecgl HTML Test
    </div>

    <div class="content">

        <h2>Hello Macho 👋</h2>

        <p>If you can see this styled window, HTML + CSS works.</p>

        <input
            id="textbox"
            placeholder="Type something..."
        >

        <button onclick="clicked()">
            Test JavaScript
        </button>

        <div id="status">
            Waiting...
        </div>

    </div>

</div>

<script>

function clicked(){

    const text=document.getElementById("textbox").value;

    document.getElementById("status").innerHTML=
        "Button worked! You typed: <b>"+text+"</b>";

    console.log("JS Works!");

}

</script>

</body>
</html>
