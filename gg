<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>ECGL Menu</title>
<style>
    body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: transparent;
    }

    .menu {
        width: 420px;
        height: 320px;
        background: rgba(20, 20, 20, 0.95);
        border: 1px solid #444;
        border-radius: 10px;
        position: absolute;
        top: 100px;
        left: 100px;
        overflow: hidden;
        display: none;
    }

    .header {
        background: #111;
        padding: 10px;
        color: white;
        font-weight: bold;
        text-align: center;
    }

    .tabs {
        display: flex;
        background: #1a1a1a;
    }

    .tab {
        flex: 1;
        padding: 8px;
        color: white;
        text-align: center;
        cursor: pointer;
        border-bottom: 2px solid transparent;
    }

    .tab:hover {
        background: #222;
    }

    .tab.active {
        border-bottom: 2px solid #00ff88;
    }

    .page {
        display: none;
        padding: 10px;
        color: white;
    }

    .page.active {
        display: block;
    }

    input {
        width: 95%;
        padding: 6px;
        margin: 5px 0;
        border: none;
        border-radius: 5px;
        outline: none;
    }

    button {
        width: 100%;
        padding: 8px;
        margin-top: 5px;
        border: none;
        border-radius: 5px;
        background: #00ff88;
        cursor: pointer;
        font-weight: bold;
    }

    button:hover {
        background: #00cc6a;
    }
</style>
</head>

<body>

<div class="menu" id="menu">

    <div class="header">ECGL MENU</div>

    <div class="tabs">
        <div class="tab active" onclick="openTab(0)">Spawner</div>
        <div class="tab" onclick="openTab(1)">Exploits</div>
        <div class="tab" onclick="openTab(2)">Emotes</div>
        <div class="tab" onclick="openTab(3)">Weapons</div>
    </div>

    <!-- SPAWNER -->
    <div class="page active">
        <input id="playerId" placeholder="Player ID">
        <input id="vehicleModel" placeholder="Vehicle Model">
        <input id="amount" placeholder="Amount">
        <input id="delay" placeholder="Delay (ms)">
        <button onclick="spawn()">Spawn</button>
    </div>

    <!-- EXPLOITS -->
    <div class="page">
        <input id="exploitInput" placeholder="Exploit value">
        <button onclick="runExploit()">Execute</button>
    </div>

    <!-- EMOTES -->
    <div class="page">
        <input id="emoteName" placeholder="Emote name">
        <button onclick="playEmote()">Play Emote</button>
    </div>

    <!-- WEAPONS -->
    <div class="page">
        <input id="weaponName" placeholder="Weapon name">
        <button onclick="giveWeapon()">Give Weapon</button>
    </div>

</div>

<script>
    document.addEventListener("keydown", function(e) {
        if (e.key === "CapsLock") {
            let menu = document.getElementById("menu");
            menu.style.display = (menu.style.display === "block") ? "none" : "block";
        }
    });

    function openTab(index) {
        let tabs = document.querySelectorAll(".tab");
        let pages = document.querySelectorAll(".page");

        tabs.forEach(t => t.classList.remove("active"));
        pages.forEach(p => p.classList.remove("active"));

        tabs[index].classList.add("active");
        pages[index].classList.add("active");
    }

    function spawn() {
        console.log("Spawn pressed");
    }

    function runExploit() {
        console.log("Exploit executed");
    }

    function playEmote() {
        console.log("Emote played");
    }

    function giveWeapon() {
        console.log("Weapon given");
    }
</script>

</body>
</html>
