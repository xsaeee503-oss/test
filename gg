<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Macho Menu</title>

<style>
body {
    margin:0;
    font-family: Arial;
    background: transparent;
}

#menu {
    width: 420px;
    height: 320px;
    background: rgba(20,20,20,0.95);
    position: absolute;
    top: 120px;
    left: 120px;
    border-radius: 10px;
    border: 1px solid #444;
    display: none;
    overflow: hidden;
}

.header {
    background:#111;
    color:white;
    text-align:center;
    padding:10px;
    font-weight:bold;
}

.tabs {
    display:flex;
    background:#1a1a1a;
}

.tab {
    flex:1;
    text-align:center;
    padding:8px;
    color:white;
    cursor:pointer;
}

.tab.active {
    border-bottom:2px solid #00ff88;
}

.page {
    display:none;
    padding:10px;
    color:white;
}

.page.active {
    display:block;
}

input {
    width:95%;
    padding:6px;
    margin:5px 0;
}

button {
    width:100%;
    padding:8px;
    background:#00ff88;
    border:none;
    cursor:pointer;
    font-weight:bold;
}
</style>
</head>

<body>

<div id="menu">

<div class="header">ECGL MENU</div>

<div class="tabs">
    <div class="tab active" onclick="openTab(0)">Spawner</div>
    <div class="tab" onclick="openTab(1)">Exploits</div>
    <div class="tab" onclick="openTab(2)">Emotes</div>
    <div class="tab" onclick="openTab(3)">Weapons</div>
</div>

<!-- SPAWNER -->
<div class="page active">
    <input id="url" placeholder="Raw GitHub URL">
    <button onclick="fetchScript()">Fetch Script</button>
</div>

<!-- EXPLOITS -->
<div class="page">
    <input id="exploit" placeholder="Value">
    <button onclick="runExploit()">Run</button>
</div>

<!-- EMOTES -->
<div class="page">
    <input id="emote" placeholder="Emote name">
    <button onclick="playEmote()">Play</button>
</div>

<!-- WEAPONS -->
<div class="page">
    <input id="weapon" placeholder="Weapon name">
    <button onclick="giveWeapon()">Give</button>
</div>

</div>

<script>

document.addEventListener("keydown", function(e){
    if(e.key === "CapsLock"){
        let m = document.getElementById("menu");
        m.style.display = (m.style.display === "block") ? "none" : "block";
    }
});

function openTab(i){
    let tabs = document.querySelectorAll(".tab");
    let pages = document.querySelectorAll(".page");

    tabs.forEach(t=>t.classList.remove("active"));
    pages.forEach(p=>p.classList.remove("active"));

    tabs[i].classList.add("active");
    pages[i].classList.add("active");
}

